# ===== Salesforce Auto Sign-In =====
# Choose ONE of these three options:

# Option A: Client Credentials Flow (RECOMMENDED for Agent API — auto-refreshes)
# Use Consumer Key & Secret from your External Client App with chatbot_api + sfap_api scopes
SF_CC_CLIENT_ID=your_external_client_app_consumer_key
SF_CC_CLIENT_SECRET=your_external_client_app_consumer_secret
SF_CC_INSTANCE_URL=https://your-org.my.salesforce.com

# Option B: Direct Access Token (simplest — no Connected App needed, but no Agent API scopes)
SF_ACCESS_TOKEN=your_salesforce_access_token
SF_INSTANCE_URL=https://your-org.my.salesforce.com

# Option C: Username-Password OAuth Flow (auto-refreshes, but may lack Agent API scopes)
SF_CLIENT_ID=your_connected_app_consumer_key
SF_CLIENT_SECRET=your_connected_app_consumer_secret
SF_USERNAME=your_salesforce_username
SF_PASSWORD=your_salesforce_password
SF_SECURITY_TOKEN=your_security_token_or_leave_empty
SF_LOGIN_URL=https://login.salesforce.com

# ===== Agent Configuration =====
SF_AGENT_ID=0XxJ60000009XUqKAM

# ===== App Configuration =====
SESSION_SECRET=your-random-session-secret
NODE_ENV=production
PORT=3000

# ===== Stress Testing =====
STRESS_BASE_URL=https://your-app.herokuapp.com
